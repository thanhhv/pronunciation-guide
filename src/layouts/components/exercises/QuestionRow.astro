---
import type { Question } from "@/data/exercises";

interface Props {
  question: Question;
}

const { question } = Astro.props;
---

<div
  class="question-row flex flex-col sm:flex-row sm:items-center gap-3 py-4 border-b border-border"
  data-question-id={question.id}
  data-answer={question.answer}
>
  <span class="text-dark font-semibold text-lg sm:w-36 sm:shrink-0">
    {question.word}<span
      class="ipa-reveal hidden text-primary text-sm font-normal ml-1"
      aria-live="polite"
    ></span>
  </span>

  <div class="options flex flex-wrap gap-2 flex-1">
    {
      question.options.map((opt) => (
        <button
          class="option-btn rounded-lg border border-primary text-primary bg-transparent px-4 py-2 text-sm font-semibold transition cursor-pointer hover:bg-primary hover:text-white"
          type="button"
          data-value={opt}
          aria-pressed="false"
        >
          {opt}
        </button>
      ))
    }
  </div>

  <button
    class="show-ipa-btn rounded-lg border border-border text-text px-3 py-2 text-sm font-semibold transition cursor-pointer hover:border-primary hover:text-primary sm:shrink-0"
    type="button"
    data-ipa={question.answer}
    aria-expanded="false"
  >
    Hiện IPA
  </button>
</div>
