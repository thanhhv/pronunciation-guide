---
import type { SentenceQuestion } from "@/data/exercises";

interface Props {
  question: SentenceQuestion;
}

const { question } = Astro.props;
const labels = ["A", "B", "C", "D"];

// Shuffle so the correct answer isn't always option A
const shuffledOptions = [...question.options].sort(() => Math.random() - 0.5);
---

<div
  class="question-row py-5 border-b border-border"
  data-question-id={question.id}
  data-answer={question.answer}
>
  <p class="text-dark font-mono text-xl font-semibold mb-4 leading-relaxed">
    {question.ipa}
  </p>
  <div class="flex flex-col gap-2">
    {
      shuffledOptions.map((opt, i) => (
        <button
          class="option-btn w-full text-left rounded-lg border border-border px-4 py-3 text-sm transition cursor-pointer hover:border-primary hover:text-primary"
          type="button"
          data-value={opt}
          aria-pressed="false"
        >
          <span class="font-bold mr-2">{labels[i]}.</span>{opt}
        </button>
      ))
    }
  </div>
</div>
