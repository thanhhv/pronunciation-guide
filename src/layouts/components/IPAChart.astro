<div class="ipa-chart" role="navigation" aria-label="Bảng 44 âm IPA tiếng Anh">

  <p class="ipa-chart__intro">Tiếng Anh chuẩn (British RP) có đúng <strong>44 âm vị</strong> — 20 nguyên âm và 24 phụ âm. Bấm vào bất kỳ ô nào để đến bài học.</p>

  <div class="ipa-chart__section ipa-chart__section--vowels">
    <div class="ipa-chart__section-header">
      <span>Nguyên Âm · Vowels</span>
      <span class="ipa-chart__section-count">20 âm</span>
    </div>
    <div class="ipa-chart__vowels-body">
      <div class="ipa-chart__sub">
        <div class="ipa-chart__sub-label">Đơn âm — Monophthongs (12)</div>
        <div class="ipa-grid ipa-grid--mono">
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-i-ngan-va-dai"><span class="ipa-cell__num">1</span><span class="ipa-cell__sym">iː</span><span class="ipa-cell__word">Sheep</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-i-ngan-va-dai"><span class="ipa-cell__num">2</span><span class="ipa-cell__sym">ɪ</span><span class="ipa-cell__word">Ship</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-u-ngan-va-dai"><span class="ipa-cell__num">3</span><span class="ipa-cell__sym">ʊ</span><span class="ipa-cell__word">Good</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-u-ngan-va-dai"><span class="ipa-cell__num">4</span><span class="ipa-cell__sym">uː</span><span class="ipa-cell__word">Shoot</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-e-va-ae"><span class="ipa-cell__num">5</span><span class="ipa-cell__sym">e</span><span class="ipa-cell__word">Bed</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-schwa"><span class="ipa-cell__num">6</span><span class="ipa-cell__sym">ə</span><span class="ipa-cell__word">Teacher</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-er"><span class="ipa-cell__num">7</span><span class="ipa-cell__sym">ɜː</span><span class="ipa-cell__word">Bird</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-o-va-o-dai"><span class="ipa-cell__num">8</span><span class="ipa-cell__sym">ɔː</span><span class="ipa-cell__word">Door</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-e-va-ae"><span class="ipa-cell__num">9</span><span class="ipa-cell__sym">æ</span><span class="ipa-cell__word">Cat</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-a-ngan-va-dai"><span class="ipa-cell__num">10</span><span class="ipa-cell__sym">ʌ</span><span class="ipa-cell__word">Up</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-a-ngan-va-dai"><span class="ipa-cell__num">11</span><span class="ipa-cell__sym">ɑː</span><span class="ipa-cell__word">Far</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-o-va-o-dai"><span class="ipa-cell__num">12</span><span class="ipa-cell__sym">ɒ</span><span class="ipa-cell__word">On</span></a>
        </div>
      </div>
      <div class="ipa-chart__sub">
        <div class="ipa-chart__sub-label">Âm đôi — Diphthongs (8)</div>
        <div class="ipa-grid ipa-grid--diph">
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-ia"><span class="ipa-cell__num">13</span><span class="ipa-cell__sym">ɪə</span><span class="ipa-cell__word">Here</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-ei"><span class="ipa-cell__num">14</span><span class="ipa-cell__sym">eɪ</span><span class="ipa-cell__word">Wait</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-ua"><span class="ipa-cell__num">15</span><span class="ipa-cell__sym">ʊə</span><span class="ipa-cell__word">Tour</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-oi"><span class="ipa-cell__num">16</span><span class="ipa-cell__sym">ɔɪ</span><span class="ipa-cell__word">Boy</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-ou"><span class="ipa-cell__num">17</span><span class="ipa-cell__sym">əʊ</span><span class="ipa-cell__word">Show</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-ea"><span class="ipa-cell__num">18</span><span class="ipa-cell__sym">eə</span><span class="ipa-cell__word">Hair</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-ai"><span class="ipa-cell__num">19</span><span class="ipa-cell__sym">aɪ</span><span class="ipa-cell__word">My</span></a>
          <a class="ipa-cell ipa-cell--v" href="/blog/nguyen-am-au"><span class="ipa-cell__num">20</span><span class="ipa-cell__sym">aʊ</span><span class="ipa-cell__word">Cow</span></a>
        </div>
      </div>
    </div>
  </div>

  <div class="ipa-chart__section ipa-chart__section--consonants">
    <div class="ipa-chart__section-header">
      <span>Phụ Âm · Consonants</span>
      <span class="ipa-chart__section-count">24 âm</span>
    </div>
    <div class="ipa-chart__cons-body">
      <div class="ipa-grid ipa-grid--cons">
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-p-va-b"><span class="ipa-cell__num">21</span><span class="ipa-cell__sym">p</span><span class="ipa-cell__word">Pea</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-p-va-b"><span class="ipa-cell__num">22</span><span class="ipa-cell__sym">b</span><span class="ipa-cell__word">Boat</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-t-va-d"><span class="ipa-cell__num">23</span><span class="ipa-cell__sym">t</span><span class="ipa-cell__word">Tea</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-t-va-d"><span class="ipa-cell__num">24</span><span class="ipa-cell__sym">d</span><span class="ipa-cell__word">Dog</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-dj-va-ch"><span class="ipa-cell__num">25</span><span class="ipa-cell__sym">tʃ</span><span class="ipa-cell__word">Cheese</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-dj-va-ch"><span class="ipa-cell__num">26</span><span class="ipa-cell__sym">dʒ</span><span class="ipa-cell__word">June</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-k-va-g"><span class="ipa-cell__num">27</span><span class="ipa-cell__sym">k</span><span class="ipa-cell__word">Car</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-k-va-g"><span class="ipa-cell__num">28</span><span class="ipa-cell__sym">g</span><span class="ipa-cell__word">Go</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-v-va-f"><span class="ipa-cell__num">29</span><span class="ipa-cell__sym">f</span><span class="ipa-cell__word">Fly</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-v-va-f"><span class="ipa-cell__num">30</span><span class="ipa-cell__sym">v</span><span class="ipa-cell__word">Video</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-th-va-dh"><span class="ipa-cell__num">31</span><span class="ipa-cell__sym">θ</span><span class="ipa-cell__word">Think</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-th-va-dh"><span class="ipa-cell__num">32</span><span class="ipa-cell__sym">ð</span><span class="ipa-cell__word">This</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-z-va-s"><span class="ipa-cell__num">33</span><span class="ipa-cell__sym">s</span><span class="ipa-cell__word">See</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-z-va-s"><span class="ipa-cell__num">34</span><span class="ipa-cell__sym">z</span><span class="ipa-cell__word">Zoo</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-sh-va-zh"><span class="ipa-cell__num">35</span><span class="ipa-cell__sym">ʃ</span><span class="ipa-cell__word">Shall</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-sh-va-zh"><span class="ipa-cell__num">36</span><span class="ipa-cell__sym">ʒ</span><span class="ipa-cell__word">Vision</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-m-va-n"><span class="ipa-cell__num">37</span><span class="ipa-cell__sym">m</span><span class="ipa-cell__word">Man</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-m-va-n"><span class="ipa-cell__num">38</span><span class="ipa-cell__sym">n</span><span class="ipa-cell__word">Now</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-ng"><span class="ipa-cell__num">39</span><span class="ipa-cell__sym">ŋ</span><span class="ipa-cell__word">Sing</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-h"><span class="ipa-cell__num">40</span><span class="ipa-cell__sym">h</span><span class="ipa-cell__word">Hat</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-l-va-r"><span class="ipa-cell__num">41</span><span class="ipa-cell__sym">l</span><span class="ipa-cell__word">Love</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-r-kieu-my"><span class="ipa-cell__num">42</span><span class="ipa-cell__sym">r</span><span class="ipa-cell__word">Red</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-w-va-v"><span class="ipa-cell__num">43</span><span class="ipa-cell__sym">w</span><span class="ipa-cell__word">Wet</span></a>
        <a class="ipa-cell ipa-cell--c" href="/blog/phu-am-j"><span class="ipa-cell__num">44</span><span class="ipa-cell__sym">j</span><span class="ipa-cell__word">Yes</span></a>
      </div>
    </div>
  </div>

  <p class="ipa-chart__footnote">Hai âm chung bài học (vd: /iː/ và /ɪ/) được dạy cùng nhau vì người Việt hay nhầm chúng. Click vào ô nào cũng đến đúng bài.</p>

</div>

<style>
  .ipa-chart {
    margin: 2rem 0 2.5rem;
    font-family: var(--font-primary);
  }

  .ipa-chart__intro {
    text-align: center;
    color: #747577;
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
  }

  .ipa-chart__intro strong {
    color: #152035;
  }

  .ipa-chart__section {
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 0.875rem;
  }

  .ipa-chart__section--vowels  { border: 2px solid #01AD9F; }
  .ipa-chart__section--consonants { border: 2px solid #E07B39; }

  .ipa-chart__section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .ipa-chart__section--vowels     .ipa-chart__section-header { background: #01AD9F; }
  .ipa-chart__section--consonants .ipa-chart__section-header { background: #E07B39; }

  .ipa-chart__section-count {
    font-weight: 400;
    font-size: 0.78rem;
    opacity: 0.85;
  }

  .ipa-chart__vowels-body {
    display: grid;
    grid-template-columns: 3fr 2fr;
  }

  .ipa-chart__sub {
    padding: 0.75rem;
  }

  .ipa-chart__sub + .ipa-chart__sub {
    border-left: 1px solid #e5e7eb;
  }

  .ipa-chart__sub-label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #9ca3af;
    margin-bottom: 0.5rem;
  }

  .ipa-chart__cons-body {
    padding: 0.75rem;
  }

  .ipa-grid {
    display: grid;
    gap: 4px;
  }

  .ipa-grid--mono { grid-template-columns: repeat(4, 1fr); }
  .ipa-grid--diph { grid-template-columns: repeat(4, 1fr); }
  .ipa-grid--cons { grid-template-columns: repeat(8, 1fr); }

  .ipa-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.2rem 0.35rem;
    border-radius: 6px;
    text-decoration: none !important;
    position: relative;
    transition: transform 0.14s ease, box-shadow 0.14s ease;
    min-height: 62px;
    cursor: pointer;
  }

  .ipa-cell--v {
    background: #f0fdfb;
    color: #152035;
  }

  .ipa-cell--c {
    background: #fff7f0;
    color: #152035;
  }

  .ipa-cell:hover {
    transform: scale(1.1);
    box-shadow: 0 4px 14px rgba(0,0,0,0.13);
    z-index: 2;
  }

  .ipa-cell--v:hover { background: #ccfbf5; }
  .ipa-cell--c:hover { background: #ffedd5; }

  .ipa-cell__num {
    position: absolute;
    top: 3px;
    left: 5px;
    font-size: 0.58rem;
    color: #9ca3af;
    line-height: 1;
    font-weight: 400;
  }

  .ipa-cell__sym {
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.2;
    color: #152035;
  }

  .ipa-cell__word {
    font-size: 0.6rem;
    color: #9ca3af;
    margin-top: 3px;
    text-align: center;
    white-space: nowrap;
  }

  .ipa-chart__footnote {
    font-size: 0.75rem;
    color: #9ca3af;
    text-align: center;
    margin-top: 0.5rem;
  }

  @media (max-width: 639px) {
    .ipa-chart__vowels-body {
      grid-template-columns: 1fr;
    }
    .ipa-chart__sub + .ipa-chart__sub {
      border-left: none;
      border-top: 1px solid #e5e7eb;
    }
    .ipa-grid--cons {
      grid-template-columns: repeat(4, 1fr);
    }
    .ipa-cell {
      min-height: 50px;
    }
    .ipa-cell__sym {
      font-size: 1.05rem;
    }
    .ipa-cell__word {
      font-size: 0.55rem;
    }
  }
</style>
