---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { markdownify, plainify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";

const articles = await getSinglePage("handbook");
// Handbook chapters form a numbered series (00, 01, ...) meant to be read in
// order, so sort by filename instead of by date (which would show newest first).
const sortedArticles = [...articles].sort((a, b) => a.id.localeCompare(b.id));
---

<Base title="Handbook" meta_title="Cẩm Nang Học Tiếng Anh">
  <section class="section">
    <div class="container">
      <h1 class="h2 page-heading mb-16 text-center">Handbook</h1>
      {
        sortedArticles.length === 0 ? (
          <p class="text-center text-text">
            Chưa có bài viết nào. Quay lại sau nhé!
          </p>
        ) : (
          <div class="row gy-5 gx-4">
            {sortedArticles.map((article) => (
              <div class="col-12 sm:col-6">
                {article.data.image && (
                  <a
                    href={`/handbook/${article.id}`}
                    class="rounded-lg block hover:text-primary overflow-hidden group"
                  >
                    <Image
                      class="group-hover:scale-[1.03] transition duration-300 w-full object-cover max-h-[260px]"
                      src={article.data.image}
                      alt={article.data.title}
                      width={445}
                      height={260}
                      loading="lazy"
                    />
                  </a>
                )}
                {article.data.date && (
                  <p class="mt-6 mb-2 text-text font-medium">
                    {dateFormat(article.data.date)}
                  </p>
                )}
                <h3 class="mb-4">
                  <a
                    href={`/handbook/${article.id}`}
                    class="block hover:text-primary transition duration-300"
                    set:html={markdownify(article.data.title)}
                  />
                </h3>
                <p class="text-text line-clamp-2">
                  {plainify(article.body ?? "")}
                </p>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Base>
