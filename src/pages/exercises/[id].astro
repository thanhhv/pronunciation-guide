---
import Base from "@/layouts/Base.astro";
import ExerciseSet from "@/components/exercises/ExerciseSet.astro";
import SentenceExerciseSet from "@/components/exercises/SentenceExerciseSet.astro";
import {
  exerciseSets,
  sentenceExerciseSets,
} from "@/data/exercises";
import type {
  ExerciseSet as ExerciseSetType,
  SentenceExerciseSet as SentenceExerciseSetType,
} from "@/data/exercises";

export function getStaticPaths() {
  const soundPaths = exerciseSets.map((set) => ({
    params: { id: set.id },
    props: { kind: "sound" as const, soundSet: set as ExerciseSetType },
  }));
  const sentencePaths = sentenceExerciseSets.map((set) => ({
    params: { id: set.id },
    props: {
      kind: "sentence" as const,
      sentenceSet: set as SentenceExerciseSetType,
    },
  }));
  return [...soundPaths, ...sentencePaths];
}

interface Props {
  kind: "sound" | "sentence";
  soundSet?: ExerciseSetType;
  sentenceSet?: SentenceExerciseSetType;
}

const { kind, soundSet, sentenceSet } = Astro.props;

const title = kind === "sound" ? soundSet!.title : sentenceSet!.title;
const description =
  kind === "sound" ? soundSet!.description : sentenceSet!.description;

const instructions =
  kind === "sound"
    ? "Chọn ký hiệu IPA đúng cho mỗi từ. Dùng nút <strong class=\"text-dark\">Hiện IPA</strong> nếu cần gợi ý, rồi nhấn <strong class=\"text-dark\">Kiểm tra kết quả</strong> khi hoàn thành."
    : "Đọc phiên âm IPA và chọn câu tiếng Anh tương ứng. Nhấn <strong class=\"text-dark\">Kiểm tra kết quả</strong> khi hoàn thành.";
---

<Base
  title={title}
  meta_title={`${title} | Bài Tập Phát Âm`}
  description={description}
>
  <section class="section !pt-10">
    <div class="container">
      <div class="mb-8">
        <a
          href="/exercises"
          class="text-sm font-medium text-primary transition-colors hover:text-dark"
        >
          ← Tất cả bài tập
        </a>
      </div>

      <p class="text-center text-text mb-12 max-w-xl mx-auto" set:html={instructions} />

      {kind === "sound" && soundSet && <ExerciseSet set={soundSet} />}
      {kind === "sentence" && sentenceSet && <SentenceExerciseSet set={sentenceSet} />}
    </div>
  </section>
</Base>
